# Database (PostgreSQL / Neon, etc.)
DATABASE_URL=

# Auth: NEXTAUTH_SECRET required (e.g. openssl rand -base64 32). NEXTAUTH_URL must be the full origin in production; in dev either set e.g. http://localhost:3000 or omit the variable entirely. Do not leave NEXTAUTH_URL= with an empty value (breaks NextAuth).
NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=
# Public site URL: must match production domain; used for metadataBase, sitemap, robots, JSON-LD; use http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=https://translation.ai

# Alibaba Cloud (OSS, video OCR, etc.)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
# Region for OSS + Video Recognition API (videorecog.{region}.aliyuncs.com). Use public id (cn-hangzhou) or oss-prefixed (oss-cn-hangzhou). Must match bucket and a region where videorecog is available.
ALIYUN_OSS_REGION=
ALIYUN_RAM_ROLE_ARN=

# Upstash Redis (distributed rate limiting). Without both vars the limiter falls back to per-container memory, which serverless essentially bypasses. Provision via Upstash console or Vercel Marketplace > Upstash; REST credentials, not TCP.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI provider API keys (server-only; never use NEXT_PUBLIC_ prefix or keys may leak to the browser)
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
# Qwen via Alibaba Cloud Model Studio. Default Singapore (intl): use key from international console; set QWEN_DASHSCOPE_REGION=cn for Beijing (dashscope.aliyuncs.com) or us for Virginia
QWEN_API_KEY=
# QWEN_DASHSCOPE_REGION=intl
# Optional full URL overrides:
# QWEN_COMPATIBLE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_TEXT_GENERATION_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# Z.AI (api.z.ai). API key from console; Bearer auth, same /api/paas/v4 paths as OpenAI-compatible client
ZHIPU_API_KEY=
TENCENT_API_KEY=
KIMI_API_KEY=
OPENAI_API_KEY=
# MiniMax (https://platform.minimax.io). Default https://api.minimax.io/v1 (optional: MINIMAX_OPENAI_BASE_URL, MINIMAX_CHAT_MODEL; alias env MINNIMAX_API_KEY)
MINIMAX_API_KEY=
SILICONFLOW_API_KEY=
# Anthropic (https://console.anthropic.com). Claude translation (Messages API). Default model claude-sonnet-4-5 (override ANTHROPIC_CLAUDE_MODEL)
ANTHROPIC_API_KEY=
# ANTHROPIC_CLAUDE_MODEL=claude-sonnet-4-5
# StepFun international. OpenAI-compatible base https://api.stepfun.ai/v1 (console: platform.stepfun.ai)
STEP_API_KEY=
MISTRAL_API_KEY=
